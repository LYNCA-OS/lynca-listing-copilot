{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lynca.local/schemas/recognition-item.schema.json",
  "title": "LYNCA Recognition Dataset Item",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "asset_id",
    "physical_card_id",
    "capture_session_id",
    "images",
    "category",
    "ground_truth",
    "critical_fields",
    "difficulty_tags",
    "ground_truth_sources",
    "reviewed_by",
    "review_status"
  ],
  "properties": {
    "asset_id": { "type": "string", "minLength": 1 },
    "physical_card_id": { "type": "string", "minLength": 1 },
    "capture_session_id": { "type": "string", "minLength": 1 },
    "source_feedback_id": { "type": ["string", "null"] },
    "split": {
      "type": ["string", "null"],
      "enum": ["development", "calibration", "held_out", "held_out_commercial", null]
    },
    "images": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["object_path", "role"],
        "properties": {
          "image_id": { "type": ["string", "null"] },
          "bucket": { "type": ["string", "null"] },
          "object_path": { "type": "string", "minLength": 1 },
          "role": {
            "type": "string",
            "enum": [
              "front_original",
              "back_original",
              "front_alternate",
              "back_alternate",
              "serial_crop",
              "checklist_code_crop",
              "collector_number_crop",
              "grade_label_crop",
              "year_product_crop",
              "surface_view",
              "additional"
            ]
          },
          "capture_angle": { "type": ["string", "null"] },
          "has_glare": { "type": "boolean" },
          "content_sha256": {
            "type": ["string", "null"],
            "pattern": "^[0-9a-f]{64}$"
          },
          "source_url": { "type": ["string", "null"] }
        }
      }
    },
    "category": {
      "type": "string",
      "enum": ["sports_card", "tcg_card", "pokemon_card", "non_standard_collectible", "unknown"]
    },
    "ground_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "year",
        "manufacturer",
        "product",
        "set",
        "players",
        "card_type",
        "insert",
        "parallel",
        "variation",
        "serial_number",
        "collector_number",
        "checklist_code",
        "attributes",
        "grade_company",
        "card_grade",
        "auto_grade",
        "grade_type"
      ],
      "properties": {
        "year": { "type": ["string", "null"] },
        "manufacturer": { "type": ["string", "null"] },
        "product": { "type": ["string", "null"] },
        "set": { "type": ["string", "null"] },
        "players": { "type": "array", "items": { "type": "string" } },
        "character": { "type": ["string", "null"] },
        "team": { "type": ["string", "null"] },
        "card_type": { "type": ["string", "null"] },
        "insert": { "type": ["string", "null"] },
        "parallel": { "type": ["string", "null"] },
        "variation": { "type": ["string", "null"] },
        "serial_number": { "type": ["string", "null"] },
        "collector_number": { "type": ["string", "null"] },
        "checklist_code": { "type": ["string", "null"] },
        "attributes": { "type": "array", "items": { "type": "string" } },
        "rc": { "type": "boolean" },
        "first_bowman": { "type": "boolean" },
        "auto": { "type": "boolean" },
        "patch": { "type": "boolean" },
        "relic": { "type": "boolean" },
        "ssp": { "type": "boolean" },
        "case_hit": { "type": "boolean" },
        "one_of_one": { "type": "boolean" },
        "grade_company": { "type": ["string", "null"] },
        "card_grade": { "type": ["string", "null"] },
        "auto_grade": { "type": ["string", "null"] },
        "grade_type": {
          "type": "string",
          "enum": ["CARD_ONLY", "AUTO_ONLY", "CARD_AND_AUTO", "AUTHENTIC", "ALTERED", "UNKNOWN"]
        }
      }
    },
    "critical_fields": {
      "type": "array",
      "items": { "type": "string" }
    },
    "difficulty_tags": {
      "type": "array",
      "items": { "type": "string" }
    },
    "ground_truth_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["field", "source_type"],
        "properties": {
          "field": { "type": "string" },
          "source_type": {
            "type": "string",
            "enum": [
              "CARD_FRONT",
              "CARD_BACK",
              "SLAB_LABEL",
              "OCR_REVIEW",
              "OPERATOR",
              "OFFICIAL_CHECKLIST",
              "INTERNAL_REGISTRY",
              "APPROVED_HISTORY",
              "UNKNOWN"
            ]
          },
          "source_ref": { "type": ["string", "null"] },
          "confidence": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
          "notes": { "type": ["string", "null"] }
        }
      }
    },
    "reviewed_by": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "review_status": {
      "type": "string",
      "enum": ["DRAFT", "SINGLE_REVIEWED", "DOUBLE_REVIEWED", "ARBITRATED", "REJECTED", "NEEDS_REVIEW"]
    },
    "notes": { "type": ["string", "null"] },
    "source_titles": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "generated_title": { "type": ["string", "null"] },
        "corrected_title": { "type": ["string", "null"] }
      }
    },
    "created_at": { "type": ["string", "null"] },
    "updated_at": { "type": ["string", "null"] }
  }
}
