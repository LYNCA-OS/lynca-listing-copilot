FROM python:3.12.8-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1 \
    HF_HOME=/opt/huggingface

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends libglib2.0-0 libgl1 ca-certificates \
  && rm -rf /var/lib/apt/lists/*

# The worker runs on CPU. Installing from the official CPU wheel index avoids
# shipping several gigabytes of unused CUDA libraries in every replica.
RUN pip install --no-cache-dir --index-url https://download.pytorch.org/whl/cpu torch==2.7.1

COPY requirements-vector.txt /app/requirements-vector.txt
RUN pip install --no-cache-dir -r /app/requirements-vector.txt

COPY app /app/app

# Pin and bake the reviewed SigLIP2 snapshot. Startup then loads only local
# files and runs one inference before readiness turns green.
RUN python -c "from transformers import AutoModel, AutoProcessor; model='google/siglip2-base-patch16-384'; revision='f775b65a79762255128c981547af89addcfe0f88'; AutoProcessor.from_pretrained(model, revision=revision); AutoModel.from_pretrained(model, revision=revision); print('siglip2 snapshot baked')"

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=90s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/readyz', timeout=3).read()"

CMD ["uvicorn", "app.main:app", "--host", "0.0.0.0", "--port", "8080", "--workers", "1", "--timeout-keep-alive", "5"]
