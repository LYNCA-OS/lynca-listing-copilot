FROM python:3.12.8-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
  && apt-get install -y --no-install-recommends ca-certificates \
  && rm -rf /var/lib/apt/lists/*

COPY requirements-vision.txt /app/requirements-vision.txt
RUN pip install --no-cache-dir -r /app/requirements-vision.txt

COPY app /app/app

EXPOSE 8080
HEALTHCHECK --interval=30s --timeout=5s --start-period=5s --retries=3 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://127.0.0.1:8080/healthz', timeout=3).read()"

CMD ["sh", "-c", "uvicorn app.vision_main:app --host 0.0.0.0 --port 8080 --workers ${WORKER_PROCESSES:-1} --timeout-keep-alive 5"]
