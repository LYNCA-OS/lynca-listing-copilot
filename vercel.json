{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    {
      "source": "/",
      "destination": "/app"
    },
    {
      "source": "/index.html",
      "destination": "/app"
    },
    {
      "source": "/login",
      "destination": "/app/login"
    },
    {
      "source": "/login.html",
      "destination": "/app/login"
    }
  ],
  "crons": [
    {
      "path": "/api/listing-storage-retention-cleanup",
      "schedule": "0 9 * * *"
    }
  ]
}
