{
  "cleanUrls": true,
  "trailingSlash": false,
  "regions": [
    "syd1"
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/app"
    },
    {
      "source": "/index.html",
      "destination": "/app"
    },
    {
      "source": "/login",
      "destination": "/app/login"
    },
    {
      "source": "/login.html",
      "destination": "/app/login"
    }
  ],
  "functions": {
    "api/listing-copilot-title.js": {
      "maxDuration": 300
    },
    "api/v4/listing-copilot-title.js": {
      "maxDuration": 300
    },
    "api/v4/fast-scout-prewarm.js": {
      "maxDuration": 300
    },
    "api/admin-import-writer-title-catalog-seed.js": {
      "maxDuration": 300,
      "includeFiles": "data/catalog/writer-title-seed/writer-ebay-upload-20260703.xlsx"
    }
  },
  "crons": [
    {
      "path": "/api/listing-storage-retention-cleanup",
      "schedule": "0 9 * * *"
    }
  ]
}
